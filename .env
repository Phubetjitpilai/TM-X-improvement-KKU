# คัดลอกไฟล์นี้เป็น ".env" ที่ root ของโปรเจกต์ (นอก Backend-pc_station/) แล้วใส่ค่าจริง
# WARNING: เปลี่ยนรหัสผ่านทุกตัวก่อนใช้งานจริง (production)

# ── Database (MySQL รันบนเครื่องโดยตรง ไม่ใช้ Docker แล้ว) ────────────────────
# DB_PORT=3306 คือ port default ของ MySQL ที่ติดตั้งบนเครื่อง (เดิม 3307 คือ
# port ที่ map ออกมาจาก Docker container ซึ่งเลิกใช้แล้ว)
DB_HOST=127.0.0.1
DB_USER=pc_user
DB_PASSWORD=password
DB_NAME=tmx_db
DB_PORT=3306

# ── Backend (main.py) / Agent (Backend-pc_station/agent_mock_up.py) ──────────
# BACKEND_URL: ใช้โดย Agent เพื่อรู้ว่า Backend อยู่ที่ไหน — ถ้า Agent รันอยู่
# คนละเครื่อง (เช่น Raspberry Pi) ให้เปลี่ยนเป็น http://<IP เครื่อง PC>:8000
BACKEND_URL=http://localhost:8000

# AGENT_HOST: ใช้โดย Backend เพื่อรู้ว่า Agent อยู่ที่ไหน (ทิศทางตรงข้ามกับ
# BACKEND_URL ด้านบน) — ตอนเทสต์บน PC เครื่องเดียว ปล่อยเป็น localhost ได้เลย
# พอมี Raspberry Pi จริงที่รัน Agent แยกเครื่อง ให้เปลี่ยนเป็น IP ของ Pi
AGENT_HOST=localhost
AGENT_PORT=9998

# IP/Port จริงของเครื่อง TM-X (ทดสอบเชื่อมต่อสำเร็จที่ 192.168.10.11:8600)
# ปล่อยว่างไว้ได้ถ้ายังไม่ต่อเครื่องจริง (agent จะ fallback เป็น 127.0.0.1:5000)
TMX_HOST=192.168.10.11
TMX_PORT=8600

# heartbeat: agent ยิง POST /api/heartbeat มาทุก HEARTBEAT_INTERVAL วิ
# backend ใช้ HEARTBEAT_TIMEOUT เช็คว่า session ที่ 'running' ยังมี Agent
# ส่งสัญญาณชีพอยู่ไหม ถ้าเงียบเกินนี้จะ mark session เป็น 'timeout' อัตโนมัติ
HEARTBEAT_INTERVAL=5
HEARTBEAT_TIMEOUT=15

# ── Image storage (ดีไซน์สรุปแล้ว) ───────────────────────────────────────────
# เลิกใช้ MinIO แล้ว (ตัวแปร MINIO_* ทั้งหมดถูกถอดออกจากโค้ดแล้ว) — รูปภาพเก็บ
# เป็นไฟล์จริงบนดิสก์ 2 จุด คนละเครื่องกัน:
#   1. TEMP_IMAGE_DIR (บนเครื่อง Agent/Pi) — ที่พักรูปชั่วคราวหลัง FTP รับจาก
#      TM-X มา ก่อนจะอัปโหลด (multipart) ต่อให้ backend แล้วลบทิ้ง
#   2. ALPL_IMAGE_DIR (บนเครื่อง PC ที่รัน backend) — ที่เก็บถาวร แยกเป็นโฟลเดอร์
#      ย่อยตาม package_size อัตโนมัติ (ดู upload_measurement_image ใน main.py)
#      ถ้าไม่ตั้งค่านี้ไว้ backend จะ default ไปที่ TM-X_Project/ALPL/ (โฟลเดอร์
#      พี่น้องกับ Backend-server/ และ Frontend/)
TEMP_IMAGE_DIR=./Store_image_temporary
ALPL_IMAGE_DIR=./ALPL

# ── FTP รับภาพจาก TM-X (รันบนเครื่อง Agent/Pi) ───────────────────────────────
# Agent เปิดเป็น FTP server ของตัวเอง (ไม่ใช่ client) รอ TM-X Controller ส่ง
# ภาพเข้ามา — ปกติจะ "ล็อก" ไม่ให้อัปโหลดอะไรได้เลย จนกว่าจะถึง trigger ของ
# แต่ละชิ้นถึงจะปลดล็อกให้รับได้ 1 ใบ (ดู arm_image_capture ใน agent.py)
# AGENT_FTP_PORT default เป็น 2121 ไม่ใช่ 21 เพราะ Linux/Pi ต้องรันเป็น root
# ถึงจะ bind พอร์ต < 1024 ได้ — ถ้าเครื่อง TM-X ตั้งปลายทางไปที่พอร์ต 21 ตรงๆ
# แก้ไม่ได้ ให้เปลี่ยนค่านี้เป็น 21 แล้วรัน agent.py ด้วย sudo แทน
AGENT_FTP_HOST=0.0.0.0
AGENT_FTP_PORT=2121
AGENT_FTP_USER=TMX
AGENT_FTP_PASS=tmx12345
# เวลารอรูปสูงสุดหลัง trigger ก่อนจะยอมวัดต่อโดยไม่มีรูป (วินาที)
AGENT_IMAGE_WAIT_TIMEOUT=10